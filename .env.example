# Copy this file to .env and fill in real values.
# NEVER commit the .env file to source control.

# Flask secret key – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-long-random-value

# Database URL (SQLite for local dev; use PostgreSQL/MySQL in production)
DATABASE_URL=sqlite:///app.db

# Application environment: development | testing | production
FLASK_ENV=development

# Optional: rate-limiting backend (defaults to in-memory)
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
